<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="application.AccueilController" styleClass="root">
    
    <!-- En-tête -->
    <top>
        <VBox styleClass="header">
            <HBox alignment="CENTER" spacing="20" styleClass="title-bar">
                <padding>
                    <Insets top="20" bottom="20" left="30" right="30"/>
                </padding>
                <Label text="Système de Gestion du Personnel et des Stagiaires" styleClass="main-title">
                    <font>
                        <Font name="System Bold" size="28"/>
                    </font>
                </Label>
            </HBox>
        </VBox>
    </top>
    
    <!-- Centre - Alertes et Retours Imminents -->
    <center>
        <VBox spacing="30" styleClass="content-container">
            <padding>
                <Insets top="40" bottom="40" left="50" right="50"/>
            </padding>
            
            <!-- Section Alertes -->
            <VBox spacing="15">
                <Label text="Alertes et Retours Imminents" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="22"/>
                    </font>
                </Label>
                
                <!-- Liste des alertes avec code couleur -->
                <ScrollPane fitToWidth="true" styleClass="alert-scroll">
                    <content>
                        <VBox fx:id="alertesContainer" spacing="10" styleClass="alertes-list">
                            <padding>
                                <Insets top="10" bottom="10" left="10" right="10"/>
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>
            
            <!-- Section Statistiques Rapides -->
            <HBox spacing="30" alignment="CENTER">
                <VBox spacing="10" alignment="CENTER" styleClass="stat-card">
                    <padding>
                        <Insets top="20" bottom="20" left="30" right="30"/>
                    </padding>
                    <Label fx:id="lblTotalStagiaires" text="0" styleClass="stat-number">
                        <font>
                            <Font name="System Bold" size="36"/>
                        </font>
                    </Label>
                    <Label text="Stagiaires Actifs" styleClass="stat-label">
                        <font>
                            <Font size="14"/>
                        </font>
                    </Label>
                </VBox>
                
                <VBox spacing="10" alignment="CENTER" styleClass="stat-card">
                    <padding>
                        <Insets top="20" bottom="20" left="30" right="30"/>
                    </padding>
                    <Label fx:id="lblTotalEcoles" text="0" styleClass="stat-number">
                        <font>
                            <Font name="System Bold" size="36"/>
                        </font>
                    </Label>
                    <Label text="Écoles Partenaires" styleClass="stat-label">
                        <font>
                            <Font size="14"/>
                        </font>
                    </Label>
                </VBox>
                
                <VBox spacing="10" alignment="CENTER" styleClass="stat-card alert-urgent">
                    <padding>
                        <Insets top="20" bottom="20" left="30" right="30"/>
                    </padding>
                    <Label fx:id="lblRetoursUrgents" text="0" styleClass="stat-number">
                        <font>
                            <Font name="System Bold" size="36"/>
                        </font>
                    </Label>
                    <Label text="Retours &lt; 2 Semaines" styleClass="stat-label">
                        <font>
                            <Font size="14"/>
                        </font>
                    </Label>
                </VBox>
            </HBox>
            
        </VBox>
    </center>
    
    <!-- Bas - Boutons d'action -->
    <bottom>
        <HBox alignment="CENTER" spacing="30" styleClass="action-bar">
            <padding>
                <Insets top="30" bottom="30" left="30" right="30"/>
            </padding>
            
            <Button text="Se Connecter" onAction="#handleLogin" styleClass="btn-primary">
                <font>
                    <Font name="System Bold" size="16"/>
                </font>
                <padding>
                    <Insets top="15" bottom="15" left="40" right="40"/>
                </padding>
            </Button>
            
            <Button text="Continuer sans Connexion" onAction="#handleContinueWithoutLogin" styleClass="btn-secondary">
                <font>
                    <Font size="14"/>
                </font>
                <padding>
                    <Insets top="15" bottom="15" left="30" right="30"/>
                </padding>
            </Button>
            
            <Button text="Quitter" onAction="#handleExit" styleClass="btn-exit">
                <font>
                    <Font size="14"/>
                </font>
                <padding>
                    <Insets top="15" bottom="15" left="30" right="30"/>
                </padding>
            </Button>
        </HBox>
    </bottom>
    
</BorderPane>