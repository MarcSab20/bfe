<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="application.LoginController" styleClass="login-root">
    
    <center>
        <VBox spacing="25" alignment="CENTER" styleClass="login-container">
            <padding>
                <Insets top="40" bottom="40" left="50" right="50"/>
            </padding>
            
            <!-- Titre -->
            <VBox spacing="10" alignment="CENTER">
                <Label text="Connexion" styleClass="login-title">
                    <font>
                        <Font name="System Bold" size="32"/>
                    </font>
                </Label>
                <Label text="Gestion du Personnel et des Stagiaires" styleClass="login-subtitle">
                    <font>
                        <Font size="14"/>
                    </font>
                </Label>
            </VBox>
            
            <!-- Formulaire -->
            <VBox spacing="20" styleClass="login-form">
                <padding>
                    <Insets top="30" bottom="30" left="40" right="40"/>
                </padding>
                
                <!-- Nom d'utilisateur -->
                <VBox spacing="8">
                    <Label text="Nom d'utilisateur" styleClass="form-label">
                        <font>
                            <Font name="System Bold" size="13"/>
                        </font>
                    </Label>
                    <TextField fx:id="txtUsername" promptText="Entrez votre nom d'utilisateur" 
                               styleClass="form-input">
                        <font>
                            <Font size="14"/>
                        </font>
                    </TextField>
                </VBox>
                
                <!-- Mot de passe -->
                <VBox spacing="8">
                    <Label text="Mot de passe" styleClass="form-label">
                        <font>
                            <Font name="System Bold" size="13"/>
                        </font>
                    </Label>
                    <PasswordField fx:id="txtPassword" promptText="Entrez votre mot de passe" 
                                   styleClass="form-input" onAction="#handleLogin">
                        <font>
                            <Font size="14"/>
                        </font>
                    </PasswordField>
                </VBox>
                
                <!-- Niveau d'accès (sélection) -->
                <VBox spacing="8">
                    <Label text="Niveau d'accès" styleClass="form-label">
                        <font>
                            <Font name="System Bold" size="13"/>
                        </font>
                    </Label>
                    <ComboBox fx:id="cmbNiveauAcces" promptText="Sélectionnez votre niveau" 
                              styleClass="form-input" prefWidth="300">
                        <items>
                            <javafx.collections.FXCollections fx:factory="observableArrayList">
                                <String fx:value="Chef de Bureau"/>
                                <String fx:value="Chargé d'Étude Assistant"/>
                            </javafx.collections.FXCollections>
                        </items>
                    </ComboBox>
                </VBox>
                
                <!-- Message d'erreur -->
                <Label fx:id="lblError" styleClass="error-message" visible="false" wrapText="true">
                    <font>
                        <Font size="12"/>
                    </font>
                </Label>
                
                <!-- Boutons -->
                <HBox spacing="15" alignment="CENTER">
                    <padding>
                        <Insets top="20"/>
                    </padding>
                    
                    <Button text="Se Connecter" onAction="#handleLogin" styleClass="btn-primary" 
                            prefWidth="150">
                        <font>
                            <Font name="System Bold" size="14"/>
                        </font>
                        <padding>
                            <Insets top="12" bottom="12" left="25" right="25"/>
                        </padding>
                    </Button>
                    
                    <Button text="Annuler" onAction="#handleCancel" styleClass="btn-secondary" 
                            prefWidth="150">
                        <font>
                            <Font size="14"/>
                        </font>
                        <padding>
                            <Insets top="12" bottom="12" left="25" right="25"/>
                        </padding>
                    </Button>
                </HBox>
            </VBox>
            
            <!-- Lien mot de passe oublié -->
            <Hyperlink text="Mot de passe oublié ?" onAction="#handleForgotPassword" 
                       styleClass="forgot-link">
                <font>
                    <Font size="12"/>
                </font>
            </Hyperlink>
            
        </VBox>
    </center>
    
</BorderPane>